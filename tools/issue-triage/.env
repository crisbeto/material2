# Angular Components Issue Triage Desk - Environment Variables Template
# Copy this file to '.env' inside the 'tools/issue-triage/' directory and fill in your values.

# 3. Local Server Port (Optional, defaults to 3000)
PORT=3000

# 4. Target Google Gemini Model (Optional, defaults to gemini-1.5-flash)
# Use 'gemini-1.5-flash' for speed/cost efficiency, or 'gemini-1.5-pro' for deep reasoning
GEMINI_MODEL=gemini-3.1-flash-lite

# 5. Target Repository Setup (Optional, defaults to angular/components)
REPO_OWNER=angular
REPO_NAME=components

# 6. Default Target Label (Optional, defaults to action: close-candidate)
# This is the custom label applied to issues approved for closure
DEFAULT_TRIAGE_LABEL="action: close-candidate"
