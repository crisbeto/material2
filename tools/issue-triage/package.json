{
  "name": "angular-issue-triage",
  "version": "1.0.0",
  "description": "Local, offline-first dashboard for triaging open issues in the angular/components repo using Google Gemini 1.5 Flash.",
  "private": true,
  "scripts": {
    "dev:server": "ts-node -O \"{\\\"module\\\":\\\"commonjs\\\"}\" server/server.ts",
    "dev:client": "ng serve",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "sweep": "ts-node -O \"{\\\"module\\\":\\\"commonjs\\\"}\" server/triage-sweep.ts",
    "learn": "ts-node -O \"{\\\"module\\\":\\\"commonjs\\\"}\" server/learn-methodology.ts",
    "close-staged": "ts-node -O \"{\\\"module\\\":\\\"commonjs\\\"}\" server/close-staged.ts",
    "build:client": "ng build --configuration production",
    "build:server": "tsc -p tsconfig.node.json",
    "build": "pnpm build:client && pnpm build:server",
    "start": "node dist/server/server.js"
  },
  "dependencies": {
    "@angular/common": "^21.0.0-next.1",
    "@angular/compiler": "^21.0.0-next.1",
    "@angular/core": "^21.0.0-next.1",
    "@angular/forms": "^21.0.0-next.1",
    "@angular/platform-browser": "^21.0.0-next.1",
    "@angular/router": "^21.0.0-next.1",
    "@google/genai": "latest",
    "@octokit/rest": "^21.0.0",
    "cors": "^2.8.5",
    "dompurify": "^3.2.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "marked": "^15.0.7",
    "rxjs": "^7.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0-next.1",
    "@angular/cli": "^21.0.0-next.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
